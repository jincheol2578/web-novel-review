# Backend environment variables
# Copy this file to .env and fill in your values

PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Supabase (required for ranking cache, autocomplete, and scheduler)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# AI API keys (at least one required for review summary)
OPENROUTER_API_KEY=your_openrouter_key_here
# Optional: Google Custom Search as fallback for review search
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CX=your_google_cx_here

# AI model for review summarization
REVIEW_MODEL=qwen/qwen3.6-plus:free

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Max concurrent novels per batch (higher = faster but more resource intensive)
MAX_CONCURRENT_NOVELS=2
